{
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "NLM_HOOK_RUNTIME=codex node \"${CODEX_PLUGIN_ROOT:-${CLAUDE_PLUGIN_ROOT}}/scripts/session-start-hook.mjs\"",
            "statusMessage": "nlm-memory: cold-start recall"
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "NLM_HOOK_RUNTIME=codex node \"${CODEX_PLUGIN_ROOT:-${CLAUDE_PLUGIN_ROOT}}/scripts/prompt-recall-hook.mjs\"",
            "statusMessage": "nlm-memory: recalling prior sessions"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "NLM_HOOK_RUNTIME=codex node \"${CODEX_PLUGIN_ROOT:-${CLAUDE_PLUGIN_ROOT}}/scripts/stop-hook.mjs\""
          }
        ]
      }
    ]
  }
}
